# Copy to `.env` for local development (see docker-compose.document-flow.yml).
# GOTENBERG_URL=http://localhost:3044
#
# Production on Render: use `render.yaml` — the API gets GOTENBERG_URL from the Gotenberg service’s
# RENDER_EXTERNAL_URL (https://…). GOTENBERG_HOSTPORT (private) is optional fallback. Or set GOTENBERG_URL manually.
# GOTENBERG_HOSTPORT=some-service:12345
# Optional: /health probe retries (Render cold start / transient 502)
# GOTENBERG_HEALTH_ATTEMPTS=5
# GOTENBERG_HEALTH_RETRY_MS=2000
# Optional: DOCX→PDF POST retries (same transient errors; rebuilds multipart each attempt)
# GOTENBERG_CONVERT_MAX_ATTEMPTS=3
# GOTENBERG_CONVERT_RETRY_MS=2500
# GOTENBERG_CONVERT_TIMEOUT_MS=180000
# Optional: LibreOffice headless — PDF → Word export and Word → PDF on the API server (no separate Gotenberg needed).
# SOFFICE_PATH=/usr/bin/soffice
# macOS:
# SOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice
# When both SOFFICE_PATH and GOTENBERG_URL are set, DOCX→PDF tries LibreOffice first, then Gotenberg on failure.
# Optional: force engine — auto (default) | soffice | gotenberg
# DOCX_TO_PDF_ENGINE=auto
#
# --- Edit PDF: download gate (Firebase Admin + optional first anonymous download) ---
# DOWNLOAD_AUTH_ENABLED=false
# When false, guests can still download without signing in, but signed-in users who send a Bearer
# token still hit the 3/day free limit (and Pro unlimited) as long as Firebase Admin + Firestore work.
# When true, GET /download requires a valid Firebase ID token OR a one-time downloadToken from POST /upload.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}   # full JSON on one line (Render secret)
# Or: GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json
#
# First download without sign-in (server-issued token from /upload). Set false to require OAuth every time.
# DOWNLOAD_FIRST_ANONYMOUS=true
#
# --- My Documents (signed-in library): POST /user-sessions/register, GET /user-sessions/library, DELETE,
# POST /user-sessions/duplicate (copy session), PATCH /user-sessions/:sessionId (rename in library) … ---
# Uses the same Firebase Admin credentials as /download when verifying Bearer tokens.
# Registers uploads/{sessionId}/owner.json (7-day retention) and writes Firestore users/{uid}/documents/{sessionId}
# via the Admin SDK (no client-side Firestore rules required for the list).
# Enable Firestore (Native mode) on the same Firebase project as the service account.
#
# Frontend: see ../frontend/.env.example — copy to frontend/.env.development and set VITE_FIREBASE_* for log in / sign up UI.
# Optional: VITE_DOWNLOAD_AUTH_ENABLED=true  (mirrors UX expectations; server still enforces when DOWNLOAD_AUTH_ENABLED=true)
# Optional: deploy firestore.rules if the client ever writes to Firestore; library list uses the API + Admin only.
#
# --- Razorpay (Pro subscription) ---
# Keys from Razorpay Dashboard → API Keys. Webhook secret: Settings → Webhooks → your endpoint → signing secret.
# RAZORPAY_KEY_ID=rzp_live_xxxx
# RAZORPAY_KEY_SECRET=xxxx
# RAZORPAY_WEBHOOK_SECRET=xxxx
# After payment.captured, the API updates Firestore (same project as Firebase Admin). Webhook URL (production):
#   https://YOUR-API-HOST/subscription/webhooks/razorpay
# Optional: grace after `expiresAt` before treating a user as free again (ms). Default 172800000 (48h).
# SUBSCRIPTION_GRACE_MS=172800000
#
# --- Public feedback (home page) ---
# GET /feedback and POST /feedback store JSON in backend/data/site-feedback.json (gitignored). Ephemeral disk on
# serverless hosts may reset the file on redeploy — migrate to a database when you need durable archives.
#
# Optional admin (list all, add curated review, delete): set a long random secret, then:
#   curl -H "Authorization: Bearer YOUR_SECRET" https://api.example.com/feedback/admin
# Frontend (not linked in nav): /admin/feedback — paste the same secret once per browser session.
# FEEDBACK_ADMIN_SECRET=   # min 16 chars, e.g. openssl rand -hex 24
