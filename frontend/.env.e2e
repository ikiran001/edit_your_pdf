# Playwright E2E (`vite --mode e2e`) — omit Firebase so Edit PDF uses anonymous download tokens
# without opening the sign-in modal (see scripts/e2e-enter-download.mjs).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
# index.html meta tags (avoid empty %VITE_SITE_URL% in e2e)
VITE_SITE_URL=http://127.0.0.1:5173
