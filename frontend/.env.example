# Copy to `.env.development` (local) or set in CI / hosting secrets for production builds.
# Firebase Console → Authentication → Sign-in method: enable Google and Email/Password as needed.
# Project overview → Project settings → Your apps → Web app → copy the firebaseConfig values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Production / GitHub Pages: public API (Render, etc.). CI also writes public/pilot-api-runtime.js.
# VITE_API_BASE_URL=https://your-api.onrender.com
#
# Local `npm run dev`: omit VITE_API_BASE_URL so /upload, /edit, /ocr-pdf, etc. use the Vite proxy to
# localhost:3001. If you set it to Render while developing, OCR/edit hit that deploy — redeploy the API
# after backend changes, or you will see stale routes (e.g. 404 on /ocr-pdf).
#
# GET /subscription/me proxied to localhost:3001 needs Firebase Admin on that local API — put the same
# one-line FIREBASE_SERVICE_ACCOUNT_JSON in backend/.env, or temporarily set VITE_API_BASE_URL to your
# deployed API (then every apiUrl() call uses that host, not only subscription).

# Optional: mirrors product expectation; server still controls enforcement via DOWNLOAD_AUTH_ENABLED.
# VITE_DOWNLOAD_AUTH_ENABLED=true
#
# Edit PDF: when Firebase Auth is ready in the browser, Download PDF first saves your work, then opens
# the sign-in modal for guests (no redirect). After sign-in, the pending download runs automatically.
# Optional stricter mode — ask for sign-in before download (signed-out users skip the one-time anonymous token).
# Set true in production together with Render: DOWNLOAD_AUTH_ENABLED=true and DOWNLOAD_FIRST_ANONYMOUS=false.
# VITE_REQUIRE_SIGN_IN_FOR_EDIT_PDF_DOWNLOAD=true
#
# Merge / Sign / Split / etc.: when Firebase Auth is ready, downloads use the same in-app sign-in modal
# (see ClientToolDownloadAuthProvider in src/app/AppRoutes.jsx).

# Microsoft Clarity — set to your Clarity Project ID (pdfpilot: wlt2nfi60x). Required for index.html placeholder at build.
VITE_CLARITY_PROJECT_ID=wlt2nfi60x
