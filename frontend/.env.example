# Copy to `.env.development` (local) or set in CI / hosting secrets for production builds.
# Firebase Console → Authentication → Sign-in method: enable Google and Email/Password as needed.
# Project overview → Project settings → Your apps → Web app → copy the firebaseConfig values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Production / GitHub Pages: public API (Render, etc.). CI also writes this into public/pdfpilot-api-config.js.
# VITE_API_BASE_URL=https://your-api.onrender.com

# Optional: mirrors product expectation; server still controls enforcement via DOWNLOAD_AUTH_ENABLED.
# VITE_DOWNLOAD_AUTH_ENABLED=true
#
# Edit PDF: when Firebase Auth is ready in the browser, Download PDF first saves your work, then opens
# the sign-in modal for guests (no redirect). After sign-in, the pending download runs automatically.
