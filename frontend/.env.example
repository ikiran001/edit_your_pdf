# Copy to `.env.development` (local) or set in CI / hosting secrets for production builds.
# Firebase Console → Authentication → Sign-in method: enable Google and Email/Password as needed.
# Project overview → Project settings → Your apps → Web app → copy the firebaseConfig values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Optional: mirrors product expectation; server still controls enforcement via DOWNLOAD_AUTH_ENABLED.
# VITE_DOWNLOAD_AUTH_ENABLED=true
