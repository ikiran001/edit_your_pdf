# GA4 — embedded at build time (same as Google’s gtag snippet).
# Change this if you point the app at a different Analytics property.
VITE_GA_MEASUREMENT_ID=G-S7NGME62Z8

# Public site URL (trailing slash) for canonical + Open Graph.
VITE_SITE_URL=https://pdfpilot.pro
# Root path when using custom domain on GitHub Pages; use /repo-name/ only for username.github.io/repo/ URLs.
VITE_BASE_PATH=/
